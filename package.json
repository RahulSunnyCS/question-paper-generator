{
  "name": "question-paper-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Question paper generator app",
  "scripts": {
    "start": "webpack serve --mode development --open",
    "build": "webpack --mode production",
    "typecheck": "tsc --noEmit",
    "dev:backend": "next dev",
    "build:backend": "next build",
    "start:backend": "next start",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .ts,.tsx src/ lib/ app/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"lib/**/*.ts\" \"app/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "next": "^15.2.2",
    "pagedjs": "^0.4.3",
    "playwright": "^1.51.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "autoprefixer": "^10.4.20",
    "css-loader": "^7.1.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "html-webpack-plugin": "^5.6.0",
    "postcss": "^8.4.49",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.8.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.15",
    "ts-loader": "^9.5.1",
    "typescript": "^5.6.3",
    "webpack": "^5.96.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.1.0"
  }
}
