{
  "name": "question-paper-generator",
  "version": "1.0.0",
  "private": true,
  "description": "Question paper generator app",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "dev:backend": "next dev",
    "build:backend": "next build",
    "start:backend": "next start",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint --ext .ts,.tsx src/ lib/ app/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"lib/**/*.ts\" \"app/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "next": "^15.2.2",
    "pagedjs": "^0.4.3",
    "playwright": "^1.51.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.1.1"
  }
}
